# ==============================================================================
# TINAI — Environment Variable Template
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL (Local: docker-compose postgres service | Prod: Neon Serverless)
# ------------------------------------------------------------------------------
POSTGRES_USER=tinai_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=tinai_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Composed DATABASE_URL used by Alembic and asyncpg in the API.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://tinai_user:changeme_strong_password@postgres:5432/tinai_db

# Alembic uses the synchronous driver variant for migrations.
# Format: postgresql://user:password@host:port/dbname
ALEMBIC_DATABASE_URL=postgresql://tinai_user:changeme_strong_password@postgres:5432/tinai_db

# Prod example (Neon): postgresql+asyncpg://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ------------------------------------------------------------------------------
# Redis Key-Space Isolation (CRITICAL — do NOT swap these values)
# tradeoffs-info §1: Celery queue backpressure must NEVER evict MAB keys.
#   DB 0 → Control-plane state (MAB weights, L1 cache, rate-limit, circuit-breakers)
#   DB 1 → Celery broker + Beat schedule (isolated from allkeys-lru eviction impact)
# ------------------------------------------------------------------------------
REDIS_URL_MAB=redis://redis:6379/0
REDIS_URL_CELERY=redis://redis:6379/1

# Prod example (Upstash): rediss://default:<token>@<host>.upstash.io:6379/0

# ------------------------------------------------------------------------------
# LLM Provider API Keys (Data Plane — external HTTP calls only, per tradeoffs-info §5)
# ------------------------------------------------------------------------------
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The fallback model is NOT a local model. It is a designated external endpoint.
# Example: a specific high-reliability model on Groq or Google AI Pro.
FALLBACK_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FALLBACK_MODEL=llama-3.3-70b-versatile
FALLBACK_BASE_URL=https://api.groq.com/openai/v1

# ------------------------------------------------------------------------------
# Observability Platforms (Celery tasks only — NEVER inline per tradeoffs-info §1)
# ------------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

ARIZE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARIZE_SPACE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# TINAI API Security (Traffic Governance — §3.8 of PRD)
# This secret is checked against the x-api-key header on all /v1/* endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ------------------------------------------------------------------------------
X_API_KEY_SECRET=changeme_generate_a_secure_random_token

# ------------------------------------------------------------------------------
# Runtime Configuration
# ------------------------------------------------------------------------------
ENVIRONMENT=dev
# dev  → chaos endpoints enabled, relaxed rate limits, verbose logging
# prod → chaos endpoints disabled, strict rate limits, structured JSON logging

# Percentage of inference requests sampled for hallucination/safety checking (3.3).
# Value: float between 0.0 and 1.0
SAFETY_SAMPLE_RATE=0.10

# Default MAB reward policy weights (tradeoffs-info §2.3: R = α·Zq - β·Zl - γ·Zc)
MAB_ALPHA=1.0
MAB_BETA=0.5
MAB_GAMMA=0.5

# EMA decay factor λ (tradeoffs-info §2.1). Do not change without re-baselining stats.
MAB_EMA_LAMBDA=0.1

# Hard TTFB timeout for all external LLM provider calls (seconds).
# PRD §3.9: abort and reroute if TTFB exceeds 1500ms.
LLM_TIMEOUT_SECONDS=1.5

# L1 prompt cache TTL in seconds (PRD §3.9: 24 hours)
CACHE_TTL_SECONDS=86400

# Default per-client daily budget ceiling in USD cents (PRD §3.8)
DEFAULT_DAILY_BUDGET_CENTS=10000.0000
